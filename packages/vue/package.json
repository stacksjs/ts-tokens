{
  "name": "vue-tokens",
  "type": "module",
  "version": "0.1.0",
  "description": "Vue 3 components for Solana tokens and NFTs",
  "author": "Chris Breuer <chris@stacksjs.com>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-tokens/tree/main/packages/vue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-tokens.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-tokens/issues"
  },
  "keywords": [
    "typescript",
    "solana",
    "token",
    "nft",
    "vue",
    "vue3",
    "components",
    "stacksjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build && bun --bun build-dts.ts",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "release": "bun publish --access public --provenance",
    "prepublishOnly": "bun --bun run build",
    "test": "bun test",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "ts-tokens": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.28",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.11",
    "better-dx": "^0.2.6",
    "bun-plugin-dtsx": "^0.21.17",
    "vite": "^7.1.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "happy-dom": "^20.11.1",
    "vue": "^3.5.28"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "bunx --bun pickier . --fix"
  }
}
